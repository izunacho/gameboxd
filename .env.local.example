# ======================
# SUPABASE CONFIGURATION
# ======================
# Get these from https://supabase.com
# In your project dashboard: Settings → API → Project Configuration

# Your Supabase project URL (looks like: https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous API key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SECRET - never expose in frontend or GitHub!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ======================
# IGDB API CONFIGURATION (via Twitch Developer)
# ======================
# ⚠️ CRITICAL: Never expose CLIENT_SECRET in frontend!
# These are server-side only - used in Next.js API Routes
# Get from: https://dev.twitch.tv/console/apps

# Your Twitch Application Client ID
IGDB_CLIENT_ID=your-twitch-client-id-here

# Your Twitch Application Client Secret (KEEP PRIVATE!)
IGDB_CLIENT_SECRET=your-twitch-client-secret-here

# ======================
# APPLICATION CONFIGURATION
# ======================
# Base URL of your application

NEXT_PUBLIC_APP_URL=http://localhost:3000
